# Crossref contact email (used for Polite Pool access)
# Replace with your email to get better rate limits and faster responses
CROSSREF_MAILTO=your.email@example.com

# OpenRouter API Key for Gemini-based validation of matches (Optional)
# If set, Gemini 2.5 Flash will be queried via OpenRouter to audit matches and catch fake citations
OPENROUTER_API_KEY=your_openrouter_api_key_here
